---
import BaseLayout from "../layouts/BaseLayout.astro";

const siteBase = "/my-notes-site/";
---

<BaseLayout title="我的学习笔记首页">
  <h1>我的学习笔记首页</h1>
  <p>这是我已经成功部署到 GitHub Pages 的个人笔记网站。</p>

  <h2>快速入口</h2>
  <ul>
    <li><a href={`${siteBase}notes/`}>进入笔记列表</a></li>
    <li><a href={`${siteBase}about/`}>查看关于页面</a></li>
    <li><a href={`${siteBase}notes/git-basic/`}>查看 Git 基础笔记</a></li>
    <li><a href={`${siteBase}notes/js-closure/`}>查看 JavaScript 闭包笔记</a></li>
  </ul>

  <h2>测试提示</h2>
  <p style="color: red; font-weight: bold; font-size: 24px;">
    如果你看到这行红字，说明首页新版本已经生效。
  </p>
</BaseLayout>
