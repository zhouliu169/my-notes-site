---
import BaseLayout from "../layouts/BaseLayout.astro";

const siteBase = "/my-notes-site/";
---

<BaseLayout title="我的学习笔记">
  <h1>我的学习笔记</h1>
  <p>这里用来记录我的学习过程、知识整理和踩坑总结。</p>

  <h2>我会写什么</h2>
  <ul>
    <li>前端基础</li>
    <li>JavaScript</li>
    <li>Git 和 GitHub</li>
    <li>开发问题记录</li>
  </ul>

  <h2>快速入口</h2>
  <ul>
    <li><a href={`${siteBase}notes/`}>查看全部笔记</a></li>
    <li><a href={`${siteBase}about/`}>关于我</a></li>
    <li><a href={`${siteBase}notes/git-basic/`}>Git 基础笔记</a></li>
    <li><a href={`${siteBase}notes/js-closure/`}>JavaScript 闭包笔记</a></li>
  </ul>

  <h2>最近计划</h2>
  <p>先搭一个最小可用的网站，然后持续添加学习笔记。</p>
</BaseLayout>
