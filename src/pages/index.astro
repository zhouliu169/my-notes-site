---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="我的学习笔记">
  <h1>我的学习笔记</h1>
  <p>这里用来记录我的学习过程、知识整理和踩坑总结。</p>

  <h2>快速入口</h2>
  <ul>
    <li><a href={`${base}notes/`}>查看全部笔记</a></li>
    <li><a href={`${base}about/`}>关于我</a></li>
    <li><a href={`${base}notes/git-basic/`}>Git 基础笔记</a></li>
    <li><a href={`${base}notes/js-closure/`}>JavaScript 闭包笔记</a></li>
  </ul>
</BaseLayout>
